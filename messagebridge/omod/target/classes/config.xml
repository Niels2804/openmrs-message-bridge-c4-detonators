<?xml version="1.0" encoding="UTF-8"?>

<module configVersion="1.2">
	
	<!-- Base Module Properties -->
	<id>messagebridge</id>
	<name>Message Bridge</name>
	<version>default</version>
	<package>org.openmrs.module.messagebridge</package>
	<author>niels</author>
	<description>
			Message Bridge module for OpenMRS
	</description>

	<activator>org.openmrs.module.messagebridge.MessageBridgeActivator</activator>	
	
	<!-- <updateURL>https://modules.openmrs.org/modules/download/messagebridge/update.rdf</updateURL> -->
	<!-- /Base Module Properties -->
	
	<require_version>2.0.0</require_version>

	<require_modules>
		<require_module version="${appframeworkVersion}">
			org.openmrs.module.appframework
		</require_module>
		<require_module version="${uiframeworkVersion}">
			org.openmrs.module.uiframework
		</require_module>
		<require_module version="${uicommonsModuleVersion}">
			org.openmrs.module.uicommons
		</require_module>
		<require_module version="${appuiVersion}">
			org.openmrs.module.appui
		</require_module>
	</require_modules>

	<aware_of_modules>
		<aware_of_module>org.openmrs.module.legacyui</aware_of_module>
	</aware_of_modules>
	
	<!-- Internationalization -->
	<!-- All message codes should start with messagebridge.* -->
	<messages>
		<lang>en</lang>
		<file>messages.properties</file>
	</messages>
	<messages>
		<lang>fr</lang>
		<file>messages_fr.properties</file>
	</messages>
	<messages>
		<lang>es</lang>
		<file>messages_es.properties</file>
	</messages>
	<!-- /Internationalization -->
	
</module>

